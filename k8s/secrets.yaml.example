# Copy to secrets.yaml and fill in real values. Never commit secrets.yaml.
#   cp k8s/secrets.yaml.example k8s/secrets.yaml
#
# Apply before the first deploy (secrets are not in kustomize overlays):
#   kubectl apply -f k8s/secrets.yaml
#   kubectl apply -k k8s/overlays/production
apiVersion: v1
kind: Secret
metadata:
  name: audiblytics-api-secrets
  namespace: audiblytics
type: Opaque
stringData:
  DATABASE_URL: "postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
  JWT_SECRET: "change-me-use-openssl-rand-hex-32"
  GEMINI_API_KEY: ""
  R2_ACCOUNT_ID: ""
  R2_ACCESS_KEY_ID: ""
  R2_SECRET_ACCESS_KEY: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: audiblytics-seed-secrets
  namespace: audiblytics
type: Opaque
stringData:
  SEED_EMAIL: "you@example.com"
  SEED_PASSWORD: "your-password"
---
# GHCR pull secret — required if packages are private (default for new GHCR images).
# Generate auth with a GitHub PAT (read:packages scope), then either:
#
#   kubectl create secret docker-registry ghcr-pull -n audiblytics \
#     --docker-server=ghcr.io \
#     --docker-username=GITHUB_USER \
#     --docker-password=GITHUB_PAT \
#     --dry-run=client -o yaml >> k8s/secrets.yaml
#
# Or fill in stringData below (delete this block if images are public).
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-pull
  namespace: audiblytics
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
    {
      "auths": {
        "ghcr.io": {
          "username": "GITHUB_USER",
          "password": "GITHUB_PAT",
          "auth": "BASE64_OF_USERNAME_COLON_PAT"
        }
      }
    }
