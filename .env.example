# Copy to .env at repo root — single source for local ports and docker compose (Path B).
# Never commit .env.

# --- Ports (./ax start, docker compose, and app .env files stay in sync) ---
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432

# Web → API proxy (Next.js server routes). Default derived from API_HOST + API_PORT.
API_HOST=127.0.0.1
API_URL=http://127.0.0.1:8000

# FastAPI CORS — must include the web origin (default derived from WEB_PORT).
CORS_ORIGINS=http://localhost:3000

# --- Secrets (docker compose Path B) ---
JWT_SECRET=change-me-use-openssl-rand-hex-32
GEMINI_API_KEY=

# Cloudflare R2 — required for voice journal recordings in API mode
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=audiblytics-recordings

# One-time seed (docker compose --profile setup run --rm seed)
SEED_EMAIL=you@example.com
SEED_PASSWORD=your-password
