#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEB="$ROOT/apps/web"
API="$ROOT/apps/api"
API_PID_FILE="$ROOT/.dev-api.pid"

usage() {
  cat <<EOF
Usage: ./dev [start|stop]

  ./dev         Start the web app (and API + Postgres when NEXT_PUBLIC_STORAGE_BACKEND=api)
  ./dev start   Same as ./dev
  ./dev stop    Stop the web dev server (and API when started by ./dev)
EOF
}

process_cwd() {
  local pid="$1"
  lsof -a -p "$pid" -d cwd -Fn 2>/dev/null | sed -n 's/^n//p' | head -1
}

is_audiblytics_web_pid() {
  local pid="$1"
  local cwd args

  cwd="$(process_cwd "$pid")"
  if [[ "$cwd" == "$WEB" || "$cwd" == "$WEB/"* ]]; then
    return 0
  fi

  args="$(ps -p "$pid" -o args= 2>/dev/null || true)"
  [[ "$args" == *"$WEB"* || ( "$args" == *"next dev"* && "$args" == *"Audiblytics"* ) ]]
}

append_unique_pid() {
  local pid="$1"
  local list="$2"

  [[ -z "$pid" ]] && { echo "$list"; return; }
  case " $list " in
    *" $pid "*) echo "$list" ;;
    *) echo "${list:+$list }$pid" ;;
  esac
}

collect_web_pids() {
  local list=""
  local pid

  if command -v lsof >/dev/null 2>&1; then
    for pid in $(lsof -ti :3000 2>/dev/null || true); do
      if is_audiblytics_web_pid "$pid"; then
        list="$(append_unique_pid "$pid" "$list")"
      fi
    done
  fi

  if command -v pgrep >/dev/null 2>&1; then
    for pid in $(pgrep -f "next dev" 2>/dev/null || true); do
      if is_audiblytics_web_pid "$pid"; then
        list="$(append_unique_pid "$pid" "$list")"
      fi
    done
  fi

  if [[ -n "$list" ]]; then
    echo "$list" | tr ' ' '\n'
  fi
}

stop_web() {
  local list pid
  list="$(collect_web_pids || true)"

  if [[ -z "$list" ]]; then
    echo "No Audiblytics web dev server running on port 3000."
    return 0
  fi

  echo "Stopping Audiblytics web dev server (PID(s): $(echo "$list" | tr '\n' ' ' | sed 's/ $//'))..."
  while IFS= read -r pid; do
    [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
  done <<< "$list"

  local waited=0
  while ((waited < 5)); do
    if [[ -z "$(collect_web_pids || true)" ]]; then
      echo "Stopped."
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done

  echo "Force-stopping remaining process(es)..."
  list="$(collect_web_pids || true)"
  while IFS= read -r pid; do
    [[ -n "$pid" ]] && kill -9 "$pid" 2>/dev/null || true
  done <<< "$list"

  echo "Stopped."
}

is_api_mode() {
  [[ -f "$WEB/.env.local" ]] && grep -q '^NEXT_PUBLIC_STORAGE_BACKEND=api' "$WEB/.env.local"
}

port_in_use() {
  local port="$1"
  lsof -ti :"$port" >/dev/null 2>&1
}

start_postgres() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "Docker is required for API mode (Postgres). Install Docker or switch to local mode." >&2
    exit 1
  fi
  if ! docker info >/dev/null 2>&1; then
    echo "Docker is not running. Start Docker Desktop, then run ./dev again." >&2
    exit 1
  fi
  echo "Starting Postgres (docker compose)..."
  (cd "$ROOT" && docker compose up -d postgres)
}

ensure_api_env() {
  if [[ ! -f "$API/.env" ]]; then
    echo "Creating apps/api/.env from .env.example..."
    cp "$API/.env.example" "$API/.env"
  fi
}

ensure_api_venv() {
  if [[ ! -d "$API/.venv" ]]; then
    echo "Creating Python venv and installing apps/api dependencies..."
    python3 -m venv "$API/.venv"
    "$API/.venv/bin/pip" install -e "${API}[dev]"
  fi
}

start_api() {
  if port_in_use 8000; then
    echo "API already listening on port 8000."
    return 0
  fi

  ensure_api_env
  ensure_api_venv

  echo "Starting FastAPI at http://127.0.0.1:8000 ..."
  (
    cd "$API"
    nohup "$API/.venv/bin/uvicorn" app.main:app --host 127.0.0.1 --port 8000 \
      >"$ROOT/.dev-api.log" 2>&1 &
    echo $! >"$API_PID_FILE"
  )

  local waited=0
  while ((waited < 30)); do
    if curl -sf "http://127.0.0.1:8000/api/v1/health" >/dev/null 2>&1; then
      echo "API ready."
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done

  echo "API did not become ready within 30s. See $ROOT/.dev-api.log" >&2
  exit 1
}

stop_api() {
  local pid=""

  if [[ -f "$API_PID_FILE" ]]; then
    pid="$(cat "$API_PID_FILE" 2>/dev/null || true)"
  fi

  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "Stopping Audiblytics API (PID $pid)..."
    kill "$pid" 2>/dev/null || true
    rm -f "$API_PID_FILE"
    echo "API stopped."
    return 0
  fi

  if port_in_use 8000; then
    local port_pid
    port_pid="$(lsof -ti :8000 2>/dev/null | head -1 || true)"
    if [[ -n "$port_pid" ]]; then
      echo "Stopping process on port 8000 (PID $port_pid)..."
      kill "$port_pid" 2>/dev/null || true
    fi
  fi

  rm -f "$API_PID_FILE"
}

start_web() {
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "pnpm is required. Install: https://pnpm.io/installation" >&2
    exit 1
  fi

  local stale
  stale="$(collect_web_pids || true)"
  if [[ -n "$stale" ]]; then
    echo "Found stale Audiblytics web dev server — cleaning up first."
    stop_web
    echo
  fi

  if [[ ! -d "$WEB/node_modules" ]]; then
    echo "Installing dependencies in apps/web..."
    (cd "$WEB" && pnpm install)
  fi

  echo "Starting Audiblytics web at http://localhost:3000"
  if is_api_mode; then
    echo "API mode detected (NEXT_PUBLIC_STORAGE_BACKEND=api)."
    start_postgres
    start_api
  fi
  echo "Press Ctrl+C to stop, or run: ./dev stop"
  echo

  cd "$WEB"
  exec pnpm dev
}

cmd="${1:-start}"

case "$cmd" in
  start)
    start_web
    ;;
  stop)
    stop_web
    stop_api
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo
    usage >&2
    exit 1
    ;;
esac
