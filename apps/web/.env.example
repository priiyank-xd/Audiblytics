# Used by scripts/generate-offline-pack.ts only. Not read by the app at runtime (AR28).
OFFLINE_PACK_PROVIDER_KEY=

# local | api — api enables FastAPI auth + Postgres-backed settings (Phase 1)
NEXT_PUBLIC_STORAGE_BACKEND=local

# Leave empty to use Next.js rewrite to API (see next.config.ts). Set for direct calls.
NEXT_PUBLIC_API_URL=

# Server-side rewrite target for /api/v1/* — set API_URL in repo root .env (./ax syncs in API mode).
API_URL=http://localhost:8000

# Optional mockup stretch UI (live feedback + AI reflection placeholders). Default off.
NEXT_PUBLIC_AUDIBLYTICS_STRETCH_UI=false
