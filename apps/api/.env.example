# Phase 1 — see architecture-v2-fastapi-backend.md BV13
# Local async URL; Neon dashboard URLs (postgresql://…) are auto-normalized to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://audiblytics:audiblytics@localhost:5432/audiblytics
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=10080
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
# Phase 2 — optional server fallback if user has not saved a key in Settings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=audiblytics-recordings
