# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
apps/web/coverage

# next.js (apps/web)
apps/web/.next/
apps/web/out/
.swc

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files — keep .env.example commit-visible (AR28 / AC11)
.env
.env*.local
!.env.example
apps/web/.env
apps/web/.env*.local
!apps/web/.env.example
apps/api/.env
apps/api/.env*.local
!apps/api/.env.example

# vercel
.vercel
apps/web/.vercel

# typescript
*.tsbuildinfo
apps/web/next-env.d.ts

# tooling caches
.eslintcache
.turbo

# IDE (keep .cursor/rules/ tracked for project conventions)
.idea/
.vscode/

# BMad user overrides (machine-local customizations)
*.user.toml

# Python (apps/api)
apps/api/.venv/
apps/api/**/__pycache__/
apps/api/**/*.py[cod]
apps/api/.pytest_cache/
apps/api/.mypy_cache/
apps/api/.ruff_cache/

# large generated artifacts (Story 8.1)
apps/web/public/offline-pack.json

# legacy root artifacts (pre-monorepo)
/.next/

# local dev orchestration (./dev)
.dev-api.pid
